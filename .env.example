# Your wallet address to receive USDC payments on Base
X402_PAY_TO_ADDRESS=0xYourWalletAddressHere

# Network: "mainnet" for Base mainnet, anything else for Base Sepolia testnet
X402_NETWORK=mainnet

# Stripe payment (optional — card payments disabled if not set)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Coinbase Commerce (optional — crypto payments via Coinbase)
COINBASE_COMMERCE_API_KEY=your_coinbase_api_key_here

# Solana Pay (optional — USDC on Solana)
SOLANA_PAY_RECIPIENT=your_solana_wallet_address

# Gumroad (optional — digital product marketplace)
GUMROAD_PRODUCT_URL=https://robbalian.gumroad.com/l/brushfit

# Lemon Squeezy (optional — tax-compliant checkout)
LEMONSQUEEZY_CHECKOUT_URL=https://robbalian.lemonsqueezy.com/checkout/buy/brushfit

# Buy Me a Coffee / Ko-fi (optional — tip jar / support)
BUYMEACOFFEE_URL=https://buymeacoffee.com/robbalian
KOFI_URL=https://ko-fi.com/robbalian

# Site URL for redirects
NEXT_PUBLIC_SITE_URL=https://agentstore.vercel.app
