          "flow": "HTTP 402 → sign USDC transfer → retry with PAYMENT-SIGNATURE header → receive PDF"
        },
        "stripe": {
          "endpoint": "https://agentstore.vercel.app/api/checkout",
          "method": "POST",
          "payment_currency": "USD",
          "flow": "POST → receive { url } → redirect to Stripe checkout"
        }
