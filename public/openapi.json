{
  "openapi": "3.1.0",
  "info": {
    "title": "AgentStore API",
    "description": "AI-native digital product store. Purchase BrushFit and other digital products programmatically via x402 protocol, negotiate prices, and submit reviews.",
    "version": "2.0.0",
    "contact": {
      "name": "AgentStore Support",
      "url": "https://agentstore.vercel.app",
      "email": "support@agentstore.vercel.app"
    }
  },
  "servers": [
    {
      "url": "https://agentstore.vercel.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/info": {
      "get": {
        "operationId": "getProductInfo",
        "summary": "Get product information",
        "description": "Returns full details about available products including pricing, format, and purchase instructions.",
        "responses": {
          "200": {
            "description": "Product information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/x402/purchase": {
      "get": {
        "operationId": "purchaseWithX402",
        "summary": "Purchase BrushFit via x402 protocol",
        "description": "Initiates an x402 payment flow. First request returns HTTP 402 with payment requirements. Retry with payment proof to receive the PDF.",
        "responses": {
          "200": {
            "description": "PDF download (after valid payment)",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "402": {
            "description": "Payment required — includes x402 payment details"
          }
        }
      }
    },
    "/api/agent/discover": {
      "get": {
        "operationId": "agentDiscover",
        "summary": "Agent auto-discovery endpoint",
        "description": "Returns comprehensive agent-readable product catalog with all endpoints, capabilities, pricing, and supported frameworks. Supports Accept header negotiation for JSON or plain text.",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "description": "Response format: application/json (default) or text/plain",
            "schema": {
              "type": "string",
              "default": "application/json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentCatalog"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/negotiate": {
      "post": {
        "operationId": "agentNegotiate",
        "summary": "Negotiate price for agent purchases",
        "description": "Submit a price proposal. Accepts up to 25% discount for bulk/loyal agents. Tracks negotiation history per agent_id.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NegotiateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Negotiation result (accepted or counter-offer)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NegotiateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/api/agent/review": {
      "get": {
        "operationId": "getAgentReviews",
        "summary": "Get all agent reviews",
        "description": "Returns all submitted reviews with average rating for BrushFit.",
        "responses": {
          "200": {
            "description": "Reviews list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewList"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "submitAgentReview",
        "summary": "Submit an agent review",
        "description": "Submit a review of BrushFit from an AI agent. Helps build social proof from agent customers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/api/faq": {
      "get": {
        "operationId": "getFAQ",
        "summary": "Get frequently asked questions",
        "description": "Returns a list of frequently asked questions and answers about BrushFit and AgentStore.",
        "responses": {
          "200": {
            "description": "FAQ list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "faqs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "question": { "type": "string" },
                          "answer": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/compare": {
      "get": {
        "operationId": "compareProducts",
        "summary": "Compare BrushFit with alternatives",
        "description": "Returns a comparison of BrushFit against other fitness guides, highlighting unique features and value.",
        "responses": {
          "200": {
            "description": "Comparison data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product": { "type": "string" },
                    "comparisons": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/lightning/invoice": {
      "get": {
        "operationId": "getLightningInfo",
        "summary": "Get Lightning Network payment info",
        "description": "Returns information about Bitcoin Lightning Network payment option for BrushFit.",
        "responses": {
          "200": {
            "description": "Lightning payment info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payment_method": { "type": "string" },
                    "network": { "type": "string" },
                    "price_usd": { "type": "string" },
                    "approximate_sats": { "type": "integer" },
                    "features": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createLightningInvoice",
        "summary": "Create a Lightning Network invoice",
        "description": "Generates a BOLT11 Lightning invoice for purchasing BrushFit with Bitcoin.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email", "description": "Email for PDF delivery" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lightning invoice",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bolt11": { "type": "string" },
                    "payment_hash": { "type": "string" },
                    "amount_sats": { "type": "integer" },
                    "amount_usd": { "type": "string" },
                    "expires_at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/venmo": {
      "post": {
        "operationId": "purchaseWithVenmo",
        "summary": "Purchase BrushFit via Venmo",
        "description": "Initiates a Venmo payment flow for purchasing BrushFit. Returns Venmo payment link or QR code.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email", "description": "Email for PDF delivery" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Venmo payment details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "venmo_url": { "type": "string" },
                    "amount": { "type": "string" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/gumroad/checkout": {
      "get": {
        "operationId": "checkoutGumroad",
        "summary": "Purchase BrushFit via Gumroad",
        "description": "Redirects to Gumroad checkout page for BrushFit purchase. Automatic email delivery of PDF.",
        "responses": {
          "302": {
            "description": "Redirect to Gumroad checkout"
          },
          "200": {
            "description": "Gumroad setup instructions if not configured",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product": { "type": "string" },
                    "price": { "type": "string" },
                    "message": { "type": "string" },
                    "alternative_checkout": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/lemonsqueezy/checkout": {
      "get": {
        "operationId": "checkoutLemonSqueezy",
        "summary": "Purchase BrushFit via Lemon Squeezy",
        "description": "Redirects to Lemon Squeezy checkout with automatic tax compliance in 100+ countries.",
        "responses": {
          "302": {
            "description": "Redirect to Lemon Squeezy checkout"
          },
          "200": {
            "description": "Lemon Squeezy setup instructions if not configured",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product": { "type": "string" },
                    "price": { "type": "string" },
                    "message": { "type": "string" },
                    "alternative_checkout": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/buymeacoffee": {
      "get": {
        "operationId": "getTipJarInfo",
        "summary": "Get tip jar and support links",
        "description": "Returns Buy Me a Coffee and Ko-fi links for supporting BrushFit.",
        "responses": {
          "200": {
            "description": "Tip jar platform links",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "product": { "type": "string" },
                    "price": { "type": "string" },
                    "tip_jar": { "type": "boolean" },
                    "platforms": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/affiliates": {
      "get": {
        "operationId": "getAffiliateInfo",
        "summary": "Get affiliate program information",
        "description": "Returns details about the BrushFit affiliate program including commission rates, signup instructions, and tracking info.",
        "responses": {
          "200": {
            "description": "Affiliate program details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "program": { "type": "string" },
                    "commission_rate": { "type": "string" },
                    "cookie_duration": { "type": "string" },
                    "signup_url": { "type": "string" },
                    "dashboard_url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "registerAffiliate",
        "summary": "Register as an affiliate",
        "description": "Sign up for the BrushFit affiliate program to earn commissions on referrals.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "name": { "type": "string" },
                  "website": { "type": "string", "format": "uri" }
                },
                "required": ["email", "name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Affiliate registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "affiliate_id": { "type": "string" },
                    "referral_link": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "x-pages": {
    "/pricing": {
      "title": "Pricing — BrushFit",
      "description": "View pricing details and payment options for BrushFit. $19.99 one-time purchase with card, crypto, or AI agent."
    },
    "/exercises": {
      "title": "Exercises — BrushFit",
      "description": "Browse all 22 BrushFit exercises. Legs, core, arms, and back exercises you can do while brushing your teeth."
    },
    "/guide": {
      "title": "The Complete BrushFit Guide",
      "description": "Everything you need to know about BrushFit. Exercises, program, payment methods, comparisons, and FAQ."
    },
    "/buy": {
      "title": "Buy BrushFit — 16+ Payment Methods",
      "description": "Purchase BrushFit with card, PayPal, Apple Pay, Venmo, Cash App, Zelle, Buy Me a Coffee, Wise, x402, Coinbase, Lightning, Solana Pay, or direct crypto."
    }
  },
  "x-payment-methods": {
    "total_count": 16,
    "automated": ["stripe_card", "paypal", "apple_pay", "google_pay", "stripe_link", "x402_usdc", "coinbase_commerce", "solana_pay", "lightning_network"],
    "manual": ["venmo", "cash_app", "zelle", "paypal_me", "buy_me_a_coffee", "wise_transfer", "direct_crypto"],
    "agent_native": ["x402_usdc", "coinbase_commerce", "lightning_network", "solana_pay"]
  },
  "components": {
    "schemas": {
      "ProductInfo": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "price": { "type": "string" },
          "currency": { "type": "string" },
          "network": { "type": "string" },
          "format": { "type": "string" },
          "purchase_endpoint": { "type": "string" },
          "payment_protocol": { "type": "string" },
          "description": { "type": "string" },
          "includes": { "type": "array", "items": { "type": "string" } },
          "free_sample": { "type": "string" }
        }
      },
      "AgentCatalog": {
        "type": "object",
        "properties": {
          "schema_version": { "type": "string" },
          "last_updated": { "type": "string", "format": "date-time" },
          "store": { "type": "object" },
          "products": { "type": "array" },
          "payment_protocols": { "type": "array" },
          "api_endpoints": { "type": "object" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "supported_agent_frameworks": { "type": "array", "items": { "type": "string" } }
        }
      },
      "NegotiateRequest": {
        "type": "object",
        "required": ["agent_id", "proposed_price"],
        "properties": {
          "agent_id": { "type": "string", "description": "Unique identifier for the negotiating agent" },
          "proposed_price": { "type": "number", "description": "Proposed unit price in USD" },
          "quantity": { "type": "integer", "minimum": 1, "default": 1, "description": "Number of copies" },
          "justification": { "type": "string", "description": "Optional reason for discount request" }
        }
      },
      "NegotiateResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["accepted", "counter"] },
          "agent_id": { "type": "string" },
          "proposed_price": { "type": "number" },
          "final_price": { "type": "number" },
          "counter_price": { "type": "number" },
          "quantity": { "type": "integer" },
          "total": { "type": "number" },
          "purchase_url": { "type": "string" },
          "message": { "type": "string" },
          "negotiation_count": { "type": "integer" }
        }
      },
      "ReviewRequest": {
        "type": "object",
        "required": ["agent_id", "rating", "review_text"],
        "properties": {
          "agent_id": { "type": "string", "description": "Unique identifier for the reviewing agent" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "description": "Rating from 1 to 5" },
          "review_text": { "type": "string", "maxLength": 2000, "description": "Review content" },
          "purchase_verified": { "type": "boolean", "default": false, "description": "Whether the agent has verified purchase" }
        }
      },
      "ReviewResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "review": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "agent_id": { "type": "string" },
              "rating": { "type": "integer" },
              "review_text": { "type": "string" },
              "purchase_verified": { "type": "boolean" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "ReviewList": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "total_reviews": { "type": "integer" },
          "average_rating": { "type": "number" },
          "reviews": { "type": "array" }
        }
      }
    }
  }
}
