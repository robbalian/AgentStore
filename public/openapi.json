{
  "openapi": "3.1.0",
  "info": {
    "title": "AgentStore API",
    "description": "AI-native digital product store. Purchase BrushFit and other digital products programmatically via x402 protocol, negotiate prices, and submit reviews.",
    "version": "1.1.0",
    "contact": {
      "name": "AgentStore Support",
      "url": "https://agentstore.vercel.app",
      "email": "support@agentstore.vercel.app"
    }
  },
  "servers": [
    {
      "url": "https://agentstore.vercel.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/info": {
      "get": {
        "operationId": "getProductInfo",
        "summary": "Get product information",
        "description": "Returns full details about available products including pricing, format, and purchase instructions.",
        "responses": {
          "200": {
            "description": "Product information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/x402/purchase": {
      "get": {
        "operationId": "purchaseWithX402",
        "summary": "Purchase BrushFit via x402 protocol",
        "description": "Initiates an x402 payment flow. First request returns HTTP 402 with payment requirements. Retry with payment proof to receive the PDF.",
        "responses": {
          "200": {
            "description": "PDF download (after valid payment)",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "402": {
            "description": "Payment required — includes x402 payment details"
          }
        }
      }
    },
    "/api/agent/discover": {
      "get": {
        "operationId": "agentDiscover",
        "summary": "Agent auto-discovery endpoint",
        "description": "Returns comprehensive agent-readable product catalog with all endpoints, capabilities, pricing, and supported frameworks. Supports Accept header negotiation for JSON or plain text.",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "description": "Response format: application/json (default) or text/plain",
            "schema": {
              "type": "string",
              "default": "application/json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentCatalog"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/negotiate": {
      "post": {
        "operationId": "agentNegotiate",
        "summary": "Negotiate price for agent purchases",
        "description": "Submit a price proposal. Accepts up to 25% discount for bulk/loyal agents. Tracks negotiation history per agent_id.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NegotiateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Negotiation result (accepted or counter-offer)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NegotiateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/api/agent/review": {
      "get": {
        "operationId": "getAgentReviews",
        "summary": "Get all agent reviews",
        "description": "Returns all submitted reviews with average rating for BrushFit.",
        "responses": {
          "200": {
            "description": "Reviews list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewList"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "submitAgentReview",
        "summary": "Submit an agent review",
        "description": "Submit a review of BrushFit from an AI agent. Helps build social proof from agent customers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductInfo": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "price": { "type": "string" },
          "currency": { "type": "string" },
          "network": { "type": "string" },
          "format": { "type": "string" },
          "purchase_endpoint": { "type": "string" },
          "payment_protocol": { "type": "string" },
          "description": { "type": "string" },
          "includes": { "type": "array", "items": { "type": "string" } },
          "free_sample": { "type": "string" }
        }
      },
      "AgentCatalog": {
        "type": "object",
        "properties": {
          "schema_version": { "type": "string" },
          "last_updated": { "type": "string", "format": "date-time" },
          "store": { "type": "object" },
          "products": { "type": "array" },
          "payment_protocols": { "type": "array" },
          "api_endpoints": { "type": "object" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "supported_agent_frameworks": { "type": "array", "items": { "type": "string" } }
        }
      },
      "NegotiateRequest": {
        "type": "object",
        "required": ["agent_id", "proposed_price"],
        "properties": {
          "agent_id": { "type": "string", "description": "Unique identifier for the negotiating agent" },
          "proposed_price": { "type": "number", "description": "Proposed unit price in USD" },
          "quantity": { "type": "integer", "minimum": 1, "default": 1, "description": "Number of copies" },
          "justification": { "type": "string", "description": "Optional reason for discount request" }
        }
      },
      "NegotiateResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["accepted", "counter"] },
          "agent_id": { "type": "string" },
          "proposed_price": { "type": "number" },
          "final_price": { "type": "number" },
          "counter_price": { "type": "number" },
          "quantity": { "type": "integer" },
          "total": { "type": "number" },
          "purchase_url": { "type": "string" },
          "message": { "type": "string" },
          "negotiation_count": { "type": "integer" }
        }
      },
      "ReviewRequest": {
        "type": "object",
        "required": ["agent_id", "rating", "review_text"],
        "properties": {
          "agent_id": { "type": "string", "description": "Unique identifier for the reviewing agent" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "description": "Rating from 1 to 5" },
          "review_text": { "type": "string", "maxLength": 2000, "description": "Review content" },
          "purchase_verified": { "type": "boolean", "default": false, "description": "Whether the agent has verified purchase" }
        }
      },
      "ReviewResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "review": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "agent_id": { "type": "string" },
              "rating": { "type": "integer" },
              "review_text": { "type": "string" },
              "purchase_verified": { "type": "boolean" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "ReviewList": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "total_reviews": { "type": "integer" },
          "average_rating": { "type": "number" },
          "reviews": { "type": "array" }
        }
      }
    }
  }
}
